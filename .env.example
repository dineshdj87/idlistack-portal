# =============================================================
# Idlistack Portal — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ---- App ----
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=idlistack
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---- Email / SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@idlistack.com

# ---- Listmonk (for alert emails) ----
LISTMONK_URL=http://localhost:9000
LISTMONK_USER=admin
LISTMONK_PASS=your_listmonk_password

# ---- Infrastructure ----
BASE_DOMAIN=idlistack.com
ACME_EMAIL=admin@idlistack.com

# Traefik dashboard auth (htpasswd format: user:hashed_pass)
# Generate: echo $(htpasswd -nb admin your_password) | sed -e s/\\$/\\$\\$/g
TRAEFIK_AUTH=admin:$$apr1$$xyz...

# ---- Docker ----
# Passwords for deployed app containers
WP_DB_PASS=change_me_wordpress_db
GHOST_DB_PASS=change_me_ghost_db
MM_DB_PASS=change_me_mattermost_db
LM_DB_PASS=change_me_listmonk_db
